# Lecture Notes Organizer — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Application
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO

# Storage
DATABASE_PATH=data/lectures.db
UPLOAD_DIR=data/uploads
MODEL_DIR=models

# AI Model Configuration
AI_DEVICE=cpu
AI_MODEL_NAME=all-MiniLM-L6-v2
AI_SPACY_MODEL=en_core_web_sm

# Security
SECRET_KEY=change-me-to-a-random-string
CORS_ORIGINS=*

# Testing
TEST_DATABASE_PATH=data/test.db